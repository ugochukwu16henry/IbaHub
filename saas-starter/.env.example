# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***
PAYSTACK_SECRET_KEY=sk_test_***
PAYSTACK_WEBHOOK_SECRET=whsec_***
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.***
PAYOUT_DELAY_MINUTES=30
CRON_SECRET=replace-with-random-long-secret
BASE_URL=http://localhost:3000
AUTH_SECRET=***

# IbaHub integration — base URLs for domain APIs (no trailing slash required).
# The app proxies authenticated requests to: /api/gateway/{logistics|gig|retail}/...
#
# Local mock upstreams (run `pnpm mock:domains` for all three, or mock:logistics / mock:gig / mock:retail separately).
# §3.5 logistics: GET /health, GET /v1/orders — port 4100 (MOCK_LOGISTICS_PORT)
# §3.5 gig: GET /health, GET /v1/rides — port 4200 (MOCK_GIG_PORT)
# §3.6 retail: GET /health, GET /api/products — port 4300 (MOCK_RETAIL_PORT)
INTEGRATION_LOGISTICS_URL=http://localhost:4100
INTEGRATION_GIG_URL=http://localhost:4200
INTEGRATION_RETAIL_URL=http://localhost:4300

# Optional: comma-separated hostnames; if set, INTEGRATION_*_URL must use one of these hosts.
# INTEGRATION_LOGISTICS_ALLOWED_HOSTS=localhost,api.example.com
# INTEGRATION_GIG_ALLOWED_HOSTS=localhost
# INTEGRATION_RETAIL_ALLOWED_HOSTS=localhost

# Optional health-check paths (defaults to /health). Used by /api/integration/health.
# INTEGRATION_LOGISTICS_HEALTH_PATH=/health
# INTEGRATION_GIG_HEALTH_PATH=/health
# INTEGRATION_RETAIL_HEALTH_PATH=/health

# Inbound cross-service webhook: POST /api/webhooks/integration
# INTEGRATION_INBOUND_WEBHOOK_SECRET=your-long-random-secret

# List endpoints for /dashboard/hub/data (defaults: v1/orders, v1/rides, api/products)
 INTEGRATION_LOGISTICS_LIST_PATH=v1/orders
 INTEGRATION_GIG_LIST_PATH=v1/rides
 INTEGRATION_RETAIL_LIST_PATH=api/products

# OIDC SSO (§3.3): set all of Issuer, client id, secret; then NEXT_PUBLIC_AUTH_SSO_ENABLED=true
# AUTH_SSO_ISSUER=https://accounts.google.com
# AUTH_SSO_CLIENT_ID=
# AUTH_SSO_CLIENT_SECRET=
# AUTH_SSO_SCOPE=openid email profile
# AUTH_SSO_PROVIDER_NAME=oidc
# NEXT_PUBLIC_AUTH_SSO_ENABLED=true

# Optional: extra CSP origins for OIDC issuer / token endpoints (space- or comma-separated hostnames/URLs)
# AUTH_SSO_CSP_ORIGINS=https://accounts.google.com https://oauth2.googleapis.com

# §3.7 Domain payouts / settlement webhook (separate from generic integration webhook)
# INTEGRATION_PAYMENTS_WEBHOOK_SECRET=your-long-random-secret
# Optional mode flags per backend (documentation only)
INTEGRATION_LOGISTICS_PAYMENT_MODE=paystack
 INTEGRATION_GIG_PAYMENT_MODE=wallet
 INTEGRATION_RETAIL_PAYMENT_MODE=paystack

# QuestPDF microservice integration (receipt/invoice/document rendering)
PDF_SERVICE_URL=http://localhost:7071
# Optional bearer token expected by the PDF service
# PDF_SERVICE_TOKEN=your-long-random-secret
# Optional branding defaults for generated docs
# IBAHUB_DOC_BRAND_NAME=IbaHub
# IBAHUB_DOC_CURRENCY=NGN

# Persist webhook events to activity_logs when teamId resolves (default on; set false to disable)
# INTEGRATION_WEBHOOK_PERSIST_ACTIVITY=true

# §3.8 — per-IP rate limit for POST /api/webhooks/* (in-process; use Redis in multi-instance prod)
# WEBHOOK_RATE_LIMIT_PER_MINUTE=120

# Rider booking slice:
# - Sign up with accountType=rider to create rider_profiles row (pending verification).
# - Public discovery endpoint (verified + available only): GET /api/riders/available
# - Nearest dispatch endpoint: GET /api/rides/nearest?pickupLat=..&pickupLng=..
# - Paystack webhook endpoint for marketplace + rides: POST /api/webhooks/paystack